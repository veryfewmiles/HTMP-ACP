<!DOCTYPE html>
<html>

<head>
    <title>Bootstrap Resize Demo</title>
    <meta charset="utf-8">

    <!-- mistake: wrong bootstrap link -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdncdn.com/bootstrap/4.3.1/css/bootstrap.min.css">

    <style>
        .box {
            padding: 10px color: black;
        }

        .red {
            background-color: red
        }

        .purple {
            background-color: #cfcfe6
        }

        .pink {
            background-color: #e6cfcf
        }

        .gray {
            background-color: #bfbfbf
        }

        .blue {
            background-color: #cfe6e6
        }
    </style>
</head>

<body>

    <h2>Hello Students!</h2>
    <p>Resize the browser window to see the effect.</p>

    <div class="container">
        <div class="row">
            <div class="col-12 box red">xs</div>
        </div>

        <div class="row">
            <div class="col-xs-3 box purple">.col-xs-3</div> <!-- mistake: old class -->
            <div class="col-9 box purple"></div>
        </div>

        <div class="row">
            <div class="col-6 box pink">.col-xs-6</div>
            <div class="col-6 box gray">.col-xs-6</div>
        </div>

        <div class="row">
            <div class="col-6 box blue">.col-xs-6</div>
            <div class="col-6 box blue">.col-xs-6</div>
        </div>
    </div>

    <h3>On resize -</h3>

    <h1>Hello Students!</h1>
    <p>Resize the browser window to see the effect.</p>

    <div class="container">
        <div class="row">
            <div class="col-12 box red">xs</div>
        </div>

        <div class="row">
            <div class="col-12 col-md-3 box purple">.col-xs-3</div>
            <div class="col-12 col-md-9 box purple"></div>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 box pink">.col-xs-6</div>
            <div class="col-12 col-md-6 box gray">.col-xs-6</div>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 box blue">.col-xs-6</div>
            <div class="col-12 col-md-6 box blue">.col-xs-6</div>
        </div>
    </div>

</body>

</html>